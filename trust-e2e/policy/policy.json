{
  "attestation": {
    "max_age_seconds": 300,
    "nonce_ttl_seconds": 180
  },
  "crypto": {
    "max_clock_skew_seconds": 45
  },
  "risk": {
    "high_risk_actions": [
      "transfer",
      "add_payee",
      "change_device"
    ],
    "velocity": {
      "window_seconds": 120,
      "max_actions": 3
    }
  },
  "authorization": {
    "enforce_owner_match": true
  },
  "graceful_degradation": {
    "max_amount": 100
  }
}
